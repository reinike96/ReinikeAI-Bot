{
    "$schema": "https://opencode.ai/config.json",
    "permission": {
        "bash": "allow",
        "read": "allow",
        "write": "allow",
        "fetch": "allow",
        "external_directory": {
            "~/OneDrive/Desktop/**": "allow"
        },
        "skill": {
            "*": "allow"
        }
    },
    "tools": {
        "file_converter_*": false,
        "word_document_*": false,
        "excel_master_*": false,
        "computer_control_*": false,
        "playwriter_*": false
    },
    "agent": {
        "build": {
            "model": "opencode/mimo-v2-pro-free",
            "variant": "high",
            "tools": {
                "playwright_browser_*": false,
                "file_converter_*": false,
                "word_document_*": false,
                "excel_master_*": false,
                "computer_control_*": false,
                "playwriter_*": false
            }
        },
        "browser": {
            "model": "opencode/mimo-v2-pro-free",
            "variant": "high",
            "tools": {
                "playwright_browser_*": true
            }
        },
        "docs": {
            "tools": {
                "playwright_browser_*": false,
                "file_converter_*": false,
                "word_document_*": false
            }
        },
        "sheets": {
            "tools": {
                "playwright_browser_*": false,
                "excel_master_*": false
            }
        },
        "computer": {
            "tools": {
                "playwright_browser_*": false,
                "computer_control_*": false
            }
        },
        "social": {
            "model": "opencode/mimo-v2-pro-free",
            "variant": "high",
            "tools": {
                "playwright_browser_*": true,
                "playwriter_*": false
            }
        }
    }
}
