<# 
.SYNOPSIS
Revisa correos de Outlook recibidos en la fecha especificada en todas las cuentas configuradas.

.DESCRIPTION
Accede a Microsoft Outlook via COM para listar correos recibidos en la fecha indicada.

.PARAMETER ShowAllAccounts
Muestra todas las cuentas (default: true)

.PARAMETER ExportToCSV
Exporta a CSV en el escritorio (default: false)

.PARAMETER DateFilter
Fecha para filtrar correos (default: hoy)

.EXAMPLE
.\check-outlook-emails.ps1

.EXAMPLE
.\check-outlook-emails.ps1 -ExportToCSV $true

.EXAMPLE
.\check-outlook-emails.ps1 -DateFilter '2026-02-21'
#>

param(
    [bool]$ShowAllAccounts = $true,
    [bool]$ExportToCSV = $false,
    [datetime]$DateFilter = (Get-Date).Date
)

try {
    $Outlook = New-Object -ComObject Outlook.Application -ErrorAction Stop
    Write-Host 'Conectado a Outlook.' -ForegroundColor Green
} catch {
    Write-Host 'Iniciando Outlook...' -ForegroundColor Yellow
    Start-Process 'C:\Program Files\Microsoft Office\root\Office16\OUTLOOK.EXE' -ArgumentList '/automation' -WindowStyle Hidden
    Start-Sleep -Seconds 5
    $Outlook = New-Object -ComObject Outlook.Application -ErrorAction Stop
}

$Namespace = $Outlook.GetNamespace('MAPI')
$Accounts = $Namespace.Folders

Write-Host "`n=== CORREOS DEL $($DateFilter.ToString('dd/MM/yyyy')) ===" -ForegroundColor Magenta
Write-Host "Cuentas: $($Accounts.Count)`n" -ForegroundColor Cyan

$todayEmails = @()
$today = $DateFilter.Date
$todayEnd = $today.AddDays(1)

foreach ($Account in $Accounts) {
    $accountName = $Account.Name
    
    try {
        $Inbox = $Account.Folders.Item('Inbox')
        $filter = "[ReceivedTime] >= '" + $today.ToString('yyyy-MM-dd HH:mm:ss') + "' AND [ReceivedTime] < '" + $todayEnd.ToString('yyyy-MM-dd HH:mm:ss') + "'"
        $todayMails = $Inbox.Items.Restrict($filter)
        $emailCount = $todayMails.Count
        
        if ($emailCount -gt 0 -or $ShowAllAccounts) {
            Write-Host "Cuenta: $accountName" -ForegroundColor White
            Write-Host "  Correos $($today.ToString('dd/MM/yyyy')): $emailCount" -ForegroundColor $(if ($emailCount -gt 0) { 'Green' } else { 'Gray' })
            
            if ($emailCount -gt 0) {
                $mailNumber = 1
                foreach ($Mail in $todayMails) {
                    $emailInfo = [PSCustomObject]@{
                        Cuenta = $accountName
                        Numero = $mailNumber
                        Asunto = $Mail.Subject
                        De = $Mail.SenderName
                        Fecha = $Mail.ReceivedTime.ToString('dd/MM/yyyy HH:mm:ss')
                        Leido = $Mail.UnRead -eq $false
                    }
                    $todayEmails += $emailInfo
                    
                    $readStatus = if ($Mail.UnRead) { '[NO LEÍDO]' } else { '[leído]' }
                    Write-Host "    $mailNumber. $readStatus $($Mail.Subject)" -ForegroundColor $(if ($Mail.UnRead) { 'Yellow' } else { 'Gray' })
                    Write-Host "       De: $($Mail.SenderName)" -ForegroundColor DarkGray
                    Write-Host "       Hora: $($Mail.ReceivedTime.ToString('HH:mm'))" -ForegroundColor DarkGray
                    
                    [System.Runtime.InteropServices.Marshal]::ReleaseComObject($Mail) | Out-Null
                    $mailNumber++
                }
            }
            Write-Host ''
            
            [System.Runtime.InteropServices.Marshal]::ReleaseComObject($Inbox) | Out-Null
            [System.Runtime.InteropServices.Marshal]::ReleaseComObject($todayMails) | Out-Null
        }
    } catch {
        if ($ShowAllAccounts) {
            Write-Host "Cuenta: $accountName" -ForegroundColor White
            Write-Host "  Error: No se pudo acceder" -ForegroundColor Red
            Write-Host ''
        }
    }
}

$totalEmails = $todayEmails.Count
Write-Host "=== RESUMEN ===" -ForegroundColor Magenta
Write-Host "Total correos $($today.ToString('dd/MM/yyyy')): $totalEmails" -ForegroundColor $(if ($totalEmails -gt 0) { 'Green' } else { 'Yellow' })

if ($ExportToCSV -and $totalEmails -gt 0) {
    $csvPath = [Environment]::GetFolderPath('Desktop') + "\correos_$($today.ToString('yyyyMMdd')).csv"
    $todayEmails | Export-Csv -Path $csvPath -NoTypeInformation -Encoding UTF8
    Write-Host "Exportado a: $csvPath" -ForegroundColor Green
}

[System.Runtime.InteropServices.Marshal]::ReleaseComObject($Accounts) | Out-Null
[System.Runtime.InteropServices.Marshal]::ReleaseComObject($Namespace) | Out-Null
[System.Runtime.InteropServices.Marshal]::ReleaseComObject($Outlook) | Out-Null

Write-Host "`nListo." -ForegroundColor Cyan